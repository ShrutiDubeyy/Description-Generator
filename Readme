│
├── src/
│   ├── attention.py             # Bahdanau attention mechanism
│   ├── dataset.py               # data loading and vocabulary
│   ├── decoder.py               # LSTM caption decoder
│   ├── encoder.py               # ResNet-50 image encoder
│   ├── model.py                 # complete model
